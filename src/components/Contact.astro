---
import SectionHeader from './SectionHeader.astro';
import MarginNote from './MarginNote.astro';
import Bilingual from './Bilingual.astro';
import LogoGD from './LogoGD.astro';
import { site } from '../data/site';

interface Props {
	showAnnotations?: boolean;
}

const { showAnnotations = true } = Astro.props;

interface ContactLink {
	it: string;
	en: string;
	text: string;
	href?: string;
	/** Show a "copy" button next to the value (e.g. for the email). */
	copy?: boolean;
}

const { email, linkedin, place, cv } = site.contact;
const links: ContactLink[] = [
	{ it: 'email', en: 'email', text: email, href: `mailto:${email}`, copy: true },
	{ it: 'linkedin', en: 'linkedin', text: linkedin.replace(/^https?:\/\//, ''), href: linkedin },
	// Il CV compare solo se `site.contact.cv` punta a un file reale in /public.
	...(cv ? [{ it: 'cv', en: 'cv', text: 'cv.pdf', href: cv } satisfies ContactLink] : []),
	{ it: 'luogo', en: 'place', text: place },
	// Solo i contatti compilati: i link vuoti restano fuori invece di puntare
	// a un href vuoto.
].filter((link) => link.text);
---

<section id="contatti" class="foglio contact" aria-label="Contatti">
	<SectionHeader latin="Colophon" it="Contatti" en="Contact" folio="f. VII v" />

	<div class="grid">
		<div>
			<h2 data-reveal>
				<Bilingual it="Raccontami la tua idea..." en="Tell me your idea..." />
			</h2>
			<ul data-reveal="stagger">
				{
					links.map((link) => (
						<li>
							<span class="key">
								<Bilingual it={link.it} en={link.en} />
							</span>
							{link.href ? (
								<a href={link.href}>{link.text}</a>
							) : (
								<span class="val">{link.text}</span>
							)}
							{link.copy && (
								<button
									type="button"
									class="copy-btn"
									data-copy={link.text}
									aria-label={`Copia ${link.text}`}
								>
									<Bilingual it="copia" en="copy" />
								</button>
							)}
						</li>
					))
				}
			</ul>
		</div>

		<div class="sign" data-reveal>
			<div class="seal">
				<LogoGD loading="lazy" />
			</div>
			<div class="signature">Gianluca</div>
			<div class="flourish" data-reveal="rule"></div>
		</div>
	</div>

	<div class="explicit" data-reveal>
		<Bilingual it="Explicit codex · Qui finisce il codice · Sperlonga MMXXVI" en="Explicit codex · Here ends the codex · Sperlonga MMXXVI" />
	</div>

	{
		showAnnotations && (
			<MarginNote style="bottom:120px;left:20px;transform:rotate(-6deg);">
					<Bilingual it="parliamone" en="let's talk" />
				</MarginNote>
		)
	}
</section>

<script>
	// Bottone "copia": mette il valore (l'email) negli appunti con feedback breve.
	document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
		btn.addEventListener('click', async () => {
			try {
				await navigator.clipboard.writeText(btn.dataset.copy ?? '');
				btn.classList.add('copied');
				window.setTimeout(() => btn.classList.remove('copied'), 1600);
			} catch {
				/* clipboard non disponibile: il link mailto resta il fallback */
			}
		});
	});
</script>

<style>
	.contact {
		padding-bottom: 90px;
	}

	.grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 220px;
		gap: 48px;
		align-items: center;
		margin-top: 40px;
	}

	h2 {
		margin: 0 0 22px;
		font-family: var(--font-hand), cursive;
		font-weight: 400;
		font-size: var(--hand-title);
		line-height: 1;
		color: var(--ink-strong);
		-webkit-font-smoothing: auto;
		text-shadow: var(--hand-bold);
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	li {
		display: flex;
		align-items: baseline;
		gap: 16px;
		padding: 11px 0;
		border-bottom: 1px solid rgba(110, 86, 56, 0.35);
	}

	li:last-child {
		border-bottom: none;
	}

	.key {
		flex: none;
		width: 130px;
		font-family: var(--font-hand), cursive;
		font-size: var(--hand-label);
		line-height: 1;
		letter-spacing: 0.015em;
		color: var(--accent-ink);
		-webkit-font-smoothing: auto;
		text-shadow: var(--hand-bold);
	}

	a,
	.val {
		font-size: clamp(20px, 2.1vw, 23px);
		line-height: 1.25;
		color: var(--ink);
		text-decoration: none;
		/* Email/URL lunghi non devono sfondare la pagina su schermi stretti. */
		word-break: break-word;
		overflow-wrap: anywhere;
	}

	a {
		border-bottom: 1px solid rgba(58, 42, 24, 0.3);
		transition: color 0.2s;
	}

	a:hover {
		color: var(--accent-ink);
	}

	/* Bottone "copia" accanto all'email: piccolo, discreto, tono rubrica. */
	.copy-btn {
		flex: none;
		padding: 3px 10px;
		font-family: var(--font-garamond), Georgia, serif;
		font-style: italic;
		font-size: 13px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--brown);
		background: rgba(156, 67, 38, 0.06);
		border: 1px solid rgba(156, 67, 38, 0.3);
		border-radius: 5px;
		cursor: pointer;
		transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
	}

	.copy-btn:hover,
	.copy-btn:focus-visible {
		color: var(--accent-ink);
		background: rgba(156, 67, 38, 0.12);
		border-color: var(--accent);
	}

	.copy-btn.copied {
		color: var(--accent-ink);
		border-color: var(--accent);
	}

	.copy-btn.copied::after {
		content: ' ✓';
	}

	.sign {
		text-align: center;
	}

	.seal {
		position: relative;
		width: 118px;
		height: 118px;
		margin: 0 auto 18px;
		display: flex;
		align-items: center;
		justify-content: center;
		transform: rotate(-7deg);
	}

	.seal :global(.logo-gd) {
		width: 112px;
	}

	.signature {
		font-family: var(--font-hand), cursive;
		font-size: var(--hand-label);
		letter-spacing: 0.02em;
		color: var(--ink-strong);
		line-height: 1;
		-webkit-font-smoothing: auto;
		text-shadow: var(--hand-bold);
	}

	.flourish {
		height: 2px;
		width: 120px;
		margin: 6px auto 0;
		background: linear-gradient(90deg, rgba(156, 67, 38, 0.15), var(--accent), rgba(156, 67, 38, 0.15));
	}

	.explicit {
		margin-top: 64px;
		text-align: center;
		font-style: italic;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		font-size: 13px;
		color: var(--brown-2);
	}

	@media (max-width: 860px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 560px) {
		/* Chiave sopra, valore sotto: niente colonna fissa che stringe l'email. */
		li {
			flex-direction: column;
			align-items: flex-start;
			gap: 4px;
		}
		.key {
			width: auto;
		}
		.explicit {
			letter-spacing: 0.1em;
		}
	}
</style>
