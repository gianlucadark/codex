---
import { Font } from 'astro:assets';
import Navbar from '../components/Navbar.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import { site } from '../data/site';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	/** Per-page OG/Twitter image (absolute or root-relative). Defaults to site.ogImage. */
	image?: string;
	/** og:type — "article" for project folios, "website" elsewhere. */
	type?: 'website' | 'article';
	/** Extra JSON-LD node(s) for this page (e.g. a CreativeWork for a project). */
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = site.title,
	description = site.description,
	image = site.ogImage,
	type = 'website',
	jsonLd,
} = Astro.props;

// Absolute URLs for canonical + social cards.
const origin = Astro.site ?? site.url;
const canonical = new URL(Astro.url.pathname, origin).href;
const ogImage = new URL(image, origin).href;

// Structured data: the author identity is present on every folio; pages can add
// their own node (a project CreativeWork) via the `jsonLd` prop.
const personLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: site.name,
	jobTitle: site.role,
	url: site.url,
	email: `mailto:${site.contact.email}`,
	sameAs: [site.contact.linkedin],
	address: { '@type': 'PostalAddress', addressLocality: site.contact.place },
};
const structuredData = [personLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];

// Same-URL bilingual: expose a shareable per-language URL for hreflang.
const enUrl = new URL(canonical);
enUrl.searchParams.set('lang', 'en');
---

<!doctype html>
<html lang="it" data-lang="it">
	<head>
		<meta charset="UTF-8" />
		<!-- Set the codex "voice" before paint to avoid a flash of the wrong language. -->
		<script is:inline>
			(function () {
				try {
					// A shareable ?lang=en|it wins over the stored preference and is
					// persisted so the choice sticks on later visits.
					var q = new URLSearchParams(location.search).get('lang');
					var l = q === 'en' || q === 'it' ? q : localStorage.getItem('codex-lang');
					if (l !== 'en') l = 'it';
					if (q === 'en' || q === 'it') localStorage.setItem('codex-lang', l);
					document.documentElement.dataset.lang = l;
					document.documentElement.lang = l;
				} catch (e) {}
			})();
		</script>
		<!-- Flag motion-capable readers pre-paint so the reveal targets can hide
		     without a flash. Skipped under reduced motion / no JS → content stays visible. -->
		<script is:inline>
			(function () {
				try {
					if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
						document.documentElement.classList.add('js-motion');
					}
				} catch (e) {}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<!-- Same-URL bilingual: point crawlers at the shareable per-language URLs. -->
		<link rel="alternate" hreflang="it" href={canonical} />
		<link rel="alternate" hreflang="en" href={enUrl.href} />
		<link rel="alternate" hreflang="x-default" href={canonical} />
		<title>{title}</title>

		<!-- Open Graph / social cards -->
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:locale" content={site.locale} />
		<meta property="og:locale:alternate" content={site.localeAlternate} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Structured data (Schema.org) -->
		<script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

		<!-- Self-hosted fonts (preloaded) via Astro Fonts API -->
		<Font cssVariable="--font-garamond" preload />
		<Font cssVariable="--font-hand" preload />
	</head>
	<body>
		<Navbar />
		<slot />
		<SmoothScroll />
	</body>
</html>
