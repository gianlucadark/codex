---
import Section from './Section.astro';
import ProjectRow from './ProjectRow.astro';
import MarginNote from './MarginNote.astro';
import Bilingual from './Bilingual.astro';
import { projects } from '../data/projects';

interface Props {
	showAnnotations?: boolean;
}

const { showAnnotations = true } = Astro.props;
---

<Section
	id="progetti"
	label="Progetti"
	latin="Tabulae Inventionum"
	it="Progetti"
	en="Work"
	folio="f. IV r"
	subtitleIt="Prodotti, strumenti ed esperienze interattive"
	subtitleEn="Products, tools and interactive experiences"
>
	<div class="list" data-reveal="stagger">
		{projects.map((project) => <ProjectRow project={project} />)}
	</div>

	{
		showAnnotations && (
			<MarginNote slot="note" style="top:60px;right:18px;transform:rotate(5deg);">
				<Bilingual it="+ molti altri…" en="+ many more…" />
			</MarginNote>
		)
	}
</Section>

<style>
	.list {
		display: flex;
		flex-direction: column;
		border-bottom: 1px solid rgba(110, 86, 56, 0.45);
	}
</style>
