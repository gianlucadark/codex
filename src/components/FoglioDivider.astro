---
/** The little rubric divider drawn between fogli — a single thin rule. */
---

<div class="divider" aria-hidden="true">
	<span class="rule" data-reveal="rule"></span>
</div>

<style>
	.divider {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 6px 0;
		opacity: 0.6;
	}

	.rule {
		height: 1px;
		width: 216px;
		background: var(--accent);
	}
</style>
