---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import CodexBackground from '../../components/CodexBackground.astro';
import FoglioDivider from '../../components/FoglioDivider.astro';
import Bilingual from '../../components/Bilingual.astro';
import { projects } from '../../data/projects';
import { site } from '../../data/site';

export function getStaticPaths() {
	return projects.map((project, i) => {
		const prev = projects[(i - 1 + projects.length) % projects.length];
		const next = projects[(i + 1) % projects.length];
		return {
			params: { slug: project.slug },
			props: { project, prev, next },
		};
	});
}

const { project, prev, next } = Astro.props;
const pageTitle = `${project.title.replace(' Browser Extension', ' Extension')} — Codex`;
const images = project.images ?? [];
const highlights = project.highlights ?? [];

// Optional "problem → approach → result" narrative, only the filled blocks.
const caseBlocks = project.caseStudy
	? [
			{ it: 'Problema', en: 'Problem', body: project.caseStudy.problem },
			{ it: 'Approccio', en: 'Approach', body: project.caseStudy.approach },
			{ it: 'Risultato', en: 'Result', body: project.caseStudy.result },
		].filter((b) => b.body)
	: [];
const technologies = project.stack
	.split('·')
	.map((t) => t.trim())
	.filter(Boolean);

// Per-project social card: reuse the first plate instead of the generic og.jpg.
const ogImage = images[0]?.src ?? site.ogImage;

// Structured data for the folio: a CreativeWork authored by the site owner.
const year = project.year.match(/\d{4}/)?.[0];
const projectLd = {
	'@context': 'https://schema.org',
	'@type': 'CreativeWork',
	name: project.title,
	description: project.descEn,
	inLanguage: ['it', 'en'],
	...(year ? { dateCreated: year } : {}),
	keywords: technologies.join(', '),
	author: { '@type': 'Person', name: site.name },
	url: new URL(`/progetti/${project.slug}`, site.url).href,
};

// Breadcrumb trail: Home › Progetti › {project}. "Progetti" is the anchor on home.
const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Codex', item: site.url },
		{ '@type': 'ListItem', position: 2, name: 'Progetti', item: new URL('/#progetti', site.url).href },
		{ '@type': 'ListItem', position: 3, name: project.title },
	],
};
---

<Layout
	title={pageTitle}
	description={`${project.desc} — ${project.descEn}`}
	image={ogImage}
	imageAlt={`${project.title} — Codex`}
	imageWidth={images[0]?.width}
	imageHeight={images[0]?.height}
	type="article"
	jsonLd={[projectLd, breadcrumbLd]}
>
	<main class="codex">
		<CodexBackground showGrid={true} showStains={true} />

		<div class="content">
			<article class="foglio detail" aria-label={`Tavola ${project.numeral}: ${project.title}`}>
				<a class="back" href="/#progetti">
					<span aria-hidden="true">←</span>
						<Bilingual it="Torna all'indice" en="Back to index" />
				</a>

				<div class="layout">
					<div class="prose">
						<h1>{project.title}</h1>
						<p class="tech">{project.stack}</p>

						<div class="prose-body">
							<div class="desc-col">
								<div class="bil-pair desc">
									<Bilingual as="p" it={project.summary} en={project.summaryEn} />
								</div>

								{
									highlights.length > 0 && (
										<section class="highlights" aria-label="Punti principali">
											<h2>
												<Bilingual it="Cosa fa" en="What it does" />
											</h2>
											<ul>
												{highlights.map((item) => (
													<li>
														<span class="mark" aria-hidden="true" />
														<Bilingual it={item.it} en={item.en} />
													</li>
												))}
											</ul>
										</section>
									)
								}

								{
									caseBlocks.length > 0 && (
										<section class="case" aria-label="Caso di studio">
											{caseBlocks.map((block) => (
												<div class="case-block">
													<h2>
														<Bilingual it={block.it} en={block.en} />
													</h2>
													<p>
														<Bilingual it={block.body!.it} en={block.body!.en} />
													</p>
												</div>
											))}
										</section>
									)
								}

								{
									project.links && project.links.length > 0 && (
										<div class="links">
											{project.links.map((link) => (
												<a class="link" href={link.href} target="_blank" rel="noopener noreferrer">
													<Bilingual it={link.it} en={link.en} />
													<span aria-hidden="true">↗</span>
												</a>
											))}
										</div>
									)
								}
							</div>

							<aside class="scheda" aria-label="Scheda tecnica">
								<h2 class="scheda-title">
									<Bilingual it="Tecnologie" en="Technologies" />
								</h2>
								<ul class="tech-list">
									{technologies.map((t) => <li>{t}</li>)}
								</ul>

								<dl class="meta">
									<div>
										<dt>
											<Bilingual it="Anno" en="Year" />
										</dt>
										<dd>{project.year}</dd>
									</div>
									<div>
										<dt>
											<Bilingual it="Ruolo" en="Role" />
										</dt>
										<dd>{project.role}</dd>
									</div>
									<div>
										<dt>
											<Bilingual it="Stato" en="Status" />
										</dt>
										<dd>{project.status}</dd>
									</div>
								</dl>
							</aside>
						</div>
					</div>

					<div class="plates" data-count={images.length}>
						{
							images.length > 0 ? (
								images.map((shot, i) => (
									<figure class="plate codex-plate">
										<div class="window">
											<Image
												src={shot}
												alt={`${project.title} — anteprima ${i + 1}`}
												widths={[480, 760, 1040]}
												sizes="(max-width: 880px) 92vw, 880px"
											/>
										</div>
										<figcaption class="caption">
											<span class="bil" lang="it">
												tav. {project.numeral}{images.length > 1 ? `.${i + 1}` : ''} · {project.title}
											</span>
											<span class="bil" lang="en">
												pl. {project.numeral}{images.length > 1 ? `.${i + 1}` : ''} · {project.title}
											</span>
										</figcaption>
									</figure>
								))
							) : (
								<figure class="plate codex-plate">
									<div class="window empty">
										<span class="slot-hint bil" lang="it">[ foto ]</span>
										<span class="slot-hint bil" lang="en">[ photo ]</span>
									</div>
									<figcaption class="caption">
										<span class="bil" lang="it">tav. {project.numeral} · {project.title}</span>
										<span class="bil" lang="en">pl. {project.numeral} · {project.title}</span>
									</figcaption>
								</figure>
							)
						}
					</div>
				</div>

				<FoglioDivider />

				<nav class="pager" aria-label="Altre tavole">
					<a class="pager-link prev" href={`/progetti/${prev.slug}`}>
						<span class="dir">
							<span aria-hidden="true">←</span>
							<Bilingual it="prec." en="prev" />
						</span>
						<span class="ptitle">{prev.title}</span>
					</a>
					<a class="pager-link next" href={`/progetti/${next.slug}`}>
						<span class="dir">
							<Bilingual it="succ." en="next" />
							<span aria-hidden="true">→</span>
						</span>
						<span class="ptitle">{next.title}</span>
					</a>
				</nav>
			</article>
		</div>
	</main>
</Layout>

<style>
	.codex {
		position: relative;
		min-height: 100vh;
		overflow: hidden;
		background: radial-gradient(
			125% 85% at 26% 10%,
			#f0e6c9 0%,
			#e8d9b5 42%,
			#ddca9f 72%,
			var(--paper) 100%
		);
		color: var(--ink);
	}

	.content {
		position: relative;
		z-index: 2;
		max-width: 980px;
		margin: 0 auto;
	}

	.detail {
		padding-bottom: 90px;
	}

	/* Back link ----------------------------------------------------------- */
	.back {
		display: inline-block;
		margin: 14px 0 28px;
		font-style: italic;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-size: 13px;
		color: var(--brown);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.back:hover {
		color: var(--accent-ink);
	}

	/* Layout: testo in alto, tavole orizzontali sotto -------------------- */
	.layout {
		display: flex;
		flex-direction: column;
		gap: clamp(36px, 5vw, 56px);
		margin-bottom: 40px;
	}

	.prose {
		border-left: 2px solid rgba(156, 67, 38, 0.5);
		padding-left: 28px;
	}

	h1 {
		margin: 0;
		font-family: var(--font-hand), cursive;
		font-weight: 400;
		font-size: clamp(44px, 6.4vw, 72px);
		line-height: 0.92;
		color: var(--ink-strong);
		-webkit-font-smoothing: auto;
		text-shadow: var(--hand-bold);
	}

	.tech {
		margin: 14px 0 24px;
		font-style: italic;
		letter-spacing: 0.06em;
		font-size: clamp(16px, 2.2vw, 20px);
		color: var(--accent-ink);
	}

	/* Corpo: descrizione a sinistra, scheda tecnica a destra -------------- */
	.prose-body {
		display: grid;
		grid-template-columns: minmax(0, 1fr) clamp(190px, 26%, 240px);
		gap: clamp(28px, 4vw, 52px);
		align-items: start;
	}

	.desc p {
		margin: 0;
		font-size: 20px;
		line-height: 1.55;
		color: var(--ink);
	}

	.highlights {
		margin-top: 28px;
	}

	.highlights h2 {
		margin: 0 0 12px;
		font-style: italic;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-size: 13px;
		font-weight: 400;
		color: var(--brown);
	}

	.highlights ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 10px;
	}

	.highlights li {
		display: grid;
		grid-template-columns: 9px minmax(0, 1fr);
		gap: 12px;
		align-items: baseline;
		font-size: 17px;
		line-height: 1.45;
		color: var(--ink);
	}

	.mark {
		width: 7px;
		height: 7px;
		margin-top: 0.45em;
		border-radius: 50%;
		background: var(--accent);
	}

	/* Caso di studio: problema → approccio → risultato (mostrato solo se compilato). */
	.case {
		margin-top: 28px;
		display: grid;
		gap: 20px;
	}

	.case-block h2 {
		margin: 0 0 6px;
		font-style: italic;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-size: 13px;
		font-weight: 400;
		color: var(--brown);
	}

	.case-block p {
		margin: 0;
		font-size: 17px;
		line-height: 1.55;
		color: var(--ink);
	}

	/* Scheda tecnica ------------------------------------------------------ */
	.scheda {
		border-top: 1.4px solid rgba(156, 67, 38, 0.5);
		padding-top: 16px;
	}

	.scheda-title {
		margin: 0 0 12px;
		font-style: italic;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-size: 13px;
		font-weight: 400;
		color: var(--brown);
	}

	.tech-list {
		list-style: none;
		margin: 0 0 22px;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tech-list li {
		font-family: var(--font-garamond), Georgia, serif;
		font-size: 15px;
		line-height: 1.15;
		padding: 6px 11px;
		color: var(--ink);
		border: 1px solid rgba(110, 86, 56, 0.5);
		background: rgba(110, 86, 56, 0.05);
	}

	.meta {
		margin: 0;
		display: grid;
		gap: 12px;
	}

	.meta dt {
		font-style: italic;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-size: 12px;
		color: var(--brown);
	}

	.meta dd {
		margin: 2px 0 0;
		font-family: var(--font-garamond), Georgia, serif;
		font-size: 16px;
		color: var(--ink-strong);
	}

	/* Links --------------------------------------------------------------- */
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 14px 26px;
		margin-top: 26px;
	}

	.link {
		font-size: 17px;
		color: var(--ink);
		text-decoration: none;
		border-bottom: 1px solid rgba(58, 42, 24, 0.3);
		transition: color 0.2s ease;
	}

	.link:hover {
		color: var(--accent-ink);
	}

	/* Tavole foto orizzontali --------------------------------------------- */
	.plates {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(24px, 4vw, 40px);
	}

	/* Con due o più scatti, affiancale su schermi larghi. */
	.plates[data-count='2'] {
		grid-template-columns: repeat(2, 1fr);
	}

	.plate {
		position: relative;
		margin: 0;
		padding: 14px;
		box-shadow: 0 14px 30px -20px rgba(58, 42, 24, 0.75);
	}

	.window {
		position: relative;
		aspect-ratio: 16 / 9;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(110, 86, 56, 0.5);
		background: repeating-linear-gradient(
			45deg,
			rgba(110, 86, 56, 0.06) 0 8px,
			transparent 8px 16px
		);
		overflow: hidden;
	}

	/* Foto reale: riempie il riquadro, mostrata originale senza effetti. */
	.window :global(img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.slot-hint {
		font-family: 'Courier New', monospace;
		font-size: 12px;
		letter-spacing: 0.05em;
		color: var(--brown-2);
	}

	.caption {
		text-align: center;
		margin-top: 12px;
		font-family: var(--font-hand), cursive;
		font-size: 21px;
		color: var(--accent-ink);
		-webkit-font-smoothing: auto;
		text-shadow: var(--hand-bold);
	}

	/* Pager --------------------------------------------------------------- */
	.pager {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 20px;
	}

	.pager-link {
		display: flex;
		flex-direction: column;
		gap: 4px;
		text-decoration: none;
		color: var(--ink-strong);
		transition: color 0.2s ease;
	}

	.pager-link.next {
		text-align: right;
	}

	.dir {
		font-style: italic;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-size: 12px;
		color: var(--brown);
	}

	.ptitle {
		font-family: var(--font-garamond), Georgia, serif;
		font-size: 19px;
		line-height: 1.15;
		transition: color 0.2s ease;
	}

	.pager-link:hover .ptitle {
		color: var(--accent-ink);
	}

	@media (max-width: 760px) {
		.layout {
			gap: 32px;
		}
		/* Su mobile descrizione e scheda vanno in colonna. */
		.prose-body {
			grid-template-columns: 1fr;
		}
		/* Su mobile le tavole tornano in colonna singola. */
		.plates[data-count='2'] {
			grid-template-columns: 1fr;
		}
		.pager {
			flex-direction: column;
			gap: 12px;
			text-align: center;
		}
		.pager-link.next {
			text-align: center;
		}
	}
</style>
