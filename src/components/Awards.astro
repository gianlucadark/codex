---
import { Image } from 'astro:assets';
import Section from './Section.astro';
import MarginNote from './MarginNote.astro';
import { awards } from '../data/awards';

interface Props {
	showAnnotations?: boolean;
}

const { showAnnotations = true } = Astro.props;

const transparentPixel =
	'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';
---

<Section
	id="riconoscimenti"
	label="Riconoscimenti"
	latin="Honores & Lauri"
	it="Riconoscimenti"
	en="Awards"
	folio="f. VII r"
	subtitleIt="I lauri del codice"
	subtitleEn="The codex's laurels"
>
	<div class="grid" data-reveal="stagger">
		{
			awards.map((award) => (
				<figure class="award">
					<div class="plate codex-plate">
						<button
							type="button"
							class="window codex-window"
							data-lightbox={award.image.src}
							data-caption={`${award.title} — ${award.category} · ${award.date}`}
							aria-label={`Ingrandisci il certificato ${award.title}`}
						>
							<Image
								src={award.image}
								alt={`Certificato ${award.title} — ${award.category}`}
								widths={[320, 640]}
								sizes="(max-width: 860px) 360px, 33vw"
								loading="lazy"
							/>
							<span class="seal hand-bold">{award.seal}</span>
							<span class="zoom-hint" aria-hidden="true">⤢</span>
						</button>
					</div>
					<figcaption>
						<span class="title hand-bold">{award.title}</span>
						<span class="meta">
							{award.category} · {award.date}
						</span>
					</figcaption>
				</figure>
			))
		}
	</div>

	<dialog class="lightbox" aria-label="Certificato ingrandito">
		<button type="button" class="lb-close" aria-label="Chiudi">×</button>
		<figure>
			<img src={transparentPixel} alt="" width="1" height="1" data-lightbox-image />
			<figcaption></figcaption>
		</figure>
	</dialog>

	{
		showAnnotations && (
			<MarginNote slot="note" style="top:64px;right:18px;transform:rotate(5deg);">
				honoris causa
			</MarginNote>
		)
	}
</Section>

<script>
	const dialog = document.querySelector<HTMLDialogElement>('.lightbox');
	if (dialog) {
		const img = dialog.querySelector('img')!;
		const caption = dialog.querySelector('figcaption')!;
		const close = () => dialog.close();

		document.querySelectorAll<HTMLButtonElement>('[data-lightbox]').forEach((btn) => {
			btn.addEventListener('click', () => {
				img.src = btn.dataset.lightbox ?? '';
				img.alt = btn.dataset.caption ?? '';
				// Il placeholder parte a 1×1 per non ingombrare la dialog chiusa:
				// tolgo gli attributi width/height così la foto reale prende la sua
				// dimensione naturale (con i cap del CSS) invece di restare a 1px.
				img.removeAttribute('width');
				img.removeAttribute('height');
				caption.textContent = btn.dataset.caption ?? '';
				dialog.showModal();
			});
		});

		dialog.querySelector('.lb-close')?.addEventListener('click', close);
		// Chiudi cliccando sullo sfondo (fuori dalla figura).
		dialog.addEventListener('click', (e) => {
			if (e.target === dialog) close();
		});
	}
</script>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(20px, 3vw, 38px);
	}

	.award {
		margin: 0;
	}

	.plate {
		position: relative;
		padding: clamp(8px, 1vw, 14px);
		box-shadow: 0 12px 28px -20px rgba(58, 42, 24, 0.75);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	/* Doppio filetto interno, come la rigatura a secco delle tavole. */
	.plate::after {
		content: '';
		position: absolute;
		inset: clamp(4px, 0.7vw, 8px);
		border: 1px solid rgba(110, 86, 56, 0.4);
		pointer-events: none;
	}

	.award:hover .plate,
	.award:focus-within .plate {
		transform: translateY(-4px);
		box-shadow: 0 18px 34px -20px rgba(58, 42, 24, 0.85);
	}

	.window {
		display: block;
		width: 100%;
		aspect-ratio: 4 / 3;
		padding: 0;
		cursor: zoom-in;
		font: inherit;
		color: inherit;
	}

	.zoom-hint {
		position: absolute;
		top: 8px;
		left: 8px;
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 4px;
		font-size: 16px;
		line-height: 1;
		color: var(--accent);
		background: rgba(212, 190, 151, 0.82);
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	.award:hover .zoom-hint,
	.window:focus-visible .zoom-hint {
		opacity: 1;
	}

	/* La foto del certificato occupa l'intero riquadro, smorzata per legarsi
	   alla carta della tavola. */
	.window :global(img) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		mix-blend-mode: multiply;
		filter: contrast(1.03) saturate(0.94) sepia(0.06);
	}

	.seal {
		position: absolute;
		bottom: 8px;
		right: 8px;
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 46px;
		height: 46px;
		border: var(--hairline) solid var(--accent);
		border-radius: 50%;
		font-family: var(--font-hand), cursive;
		font-size: 22px;
		letter-spacing: 0.02em;
		color: var(--accent-ink);
		background: rgba(212, 190, 151, 0.9);
	}

	figcaption {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		margin-top: 14px;
	}

	.title {
		font-family: var(--font-hand), cursive;
		font-size: var(--hand-caption);
		letter-spacing: 0.02em;
		line-height: 1.05;
		color: var(--accent-ink);
	}

	.meta {
		margin-top: 4px;
		font-style: italic;
		letter-spacing: 0.13em;
		text-transform: uppercase;
		font-size: 14px;
		color: var(--brown);
	}

	@media (max-width: 860px) {
		.grid {
			grid-template-columns: 1fr;
			max-width: 360px;
			margin: 0 auto;
		}
	}

	/* Lightbox: il certificato a piena risoluzione, come una tavola sciolta. */
	.lightbox {
		position: fixed;
		inset: 0;
		margin: auto;
		width: max-content;
		max-width: min(92vw, 720px);
		max-height: 92vh;
		overflow: visible;
		padding: clamp(10px, 1.4vw, 18px);
		border: var(--hairline) solid var(--brown-3);
		background: linear-gradient(180deg, var(--plate-top), var(--plate-bottom));
		box-shadow: 0 30px 70px -30px rgba(58, 42, 24, 0.9);
	}

	.lightbox::backdrop {
		background: rgba(36, 26, 14, 0.62);
		backdrop-filter: blur(2px);
	}

	.lightbox figure {
		margin: 0;
	}

	.lightbox img {
		display: block;
		max-width: 100%;
		max-height: 78vh;
		margin: 0 auto;
		object-fit: contain;
		border: 1px solid rgba(110, 86, 56, 0.5);
	}

	.lightbox figcaption {
		margin-top: 12px;
		text-align: center;
		font-style: italic;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-size: 13px;
		color: var(--brown);
	}

	.lb-close {
		position: absolute;
		top: 6px;
		right: 6px;
		z-index: 1;
		width: 36px;
		height: 36px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: var(--hairline) solid var(--brown-3);
		border-radius: 50%;
		background: var(--plate-top);
		color: var(--accent);
		font-size: 22px;
		line-height: 1;
		cursor: pointer;
		box-shadow: 0 6px 16px -8px rgba(58, 42, 24, 0.8);
	}
</style>
