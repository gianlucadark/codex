---
import SectionHeader from './SectionHeader.astro';
import Bilingual from './Bilingual.astro';
import { skillGroups as groups } from '../data/skills';
---

<section id="competenze" class="foglio" aria-label="Competenze">
	<SectionHeader latin="Artes & Instrumenta" it="Competenze" en="Skills" folio="f. VI r" />

	<div class="grid" data-reveal="stagger">
		{
			groups.map((group) => (
				<div class="group">
					<h3>{group.title}</h3>
					<p class="group-desc">
						<Bilingual it={group.descIt} en={group.descEn} />
					</p>
					<div class="rule" />
					<ul>
						{group.items.map((item) => (
							<li>
								<span class="bullet" />
								{item}
							</li>
						))}
					</ul>
				</div>
			))
		}
	</div>
</section>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
		gap: 38px;
		margin-top: 38px;
	}

	h3 {
		margin: 0 0 4px;
		font-family: var(--font-hand), cursive;
		font-weight: 400;
		font-size: 34px;
		color: var(--accent-ink);
		line-height: 1;
		-webkit-font-smoothing: auto;
		text-shadow: var(--hand-bold);
	}

	.group-desc {
		margin: 8px 0 0;
		min-height: 3.1em;
		font-size: 17px;
		line-height: 1.35;
		color: var(--ink-soft);
	}

	.rule {
		height: 1px;
		background: rgba(110, 86, 56, 0.5);
		margin: 8px 0 16px;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
		font-size: 18px;
		color: var(--ink);
	}

	li {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 5px 0;
	}

	.bullet {
		width: 7px;
		height: 7px;
		background: var(--accent);
		border-radius: 50%;
		flex: none;
	}
</style>
